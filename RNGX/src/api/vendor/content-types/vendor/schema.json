{
  "kind": "collectionType",
  "collectionName": "vendors",
  "info": {
    "singularName": "vendor",
    "pluralName": "vendors",
    "displayName": "vendor"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "coupons": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::coupon.coupon",
      "mappedBy": "coupon_vendor"
    },
    "vendor_name": {
      "type": "string"
    },
    "vendor_tile_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "vendor_hero_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "vendor_booth_location": {
      "type": "string"
    },
    "vendor_about": {
      "type": "richtext"
    },
    "vendor_web_link": {
      "type": "string"
    },
    "vendor_social_medias": {
      "type": "component",
      "component": "shared.social-media-links",
      "repeatable": true
    },
    "vendor_contact_info": {
      "type": "component",
      "component": "shared.contact-info",
      "repeatable": false
    },
    "vendor_events": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::event.event",
      "mappedBy": "vendors"
    }
  }
}
