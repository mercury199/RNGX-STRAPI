{
  "kind": "collectionType",
  "collectionName": "badges",
  "info": {
    "singularName": "badge",
    "pluralName": "badges",
    "displayName": "badge"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "bage_id": {
      "type": "uid"
    },
    "badge_event": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::event.event"
    },
    "badge_owner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "user_badges"
    },
    "badge_tiers": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-tier.user-tier"
    },
    "badge_attendee_experiences": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::experience.experience",
      "inversedBy": "experience_attendees"
    },
    "experiences": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::experience.experience",
      "inversedBy": "experience_attendee_waitlist"
    },
    "badge_email": {
      "type": "email"
    },
    "badge_activation_code": {
      "type": "string"
    },
    "badge_activation_status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "active",
        "revoked",
        "disabled"
      ]
    }
  }
}
